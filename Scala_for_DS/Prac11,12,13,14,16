# 14. Generate a histogram of a dataset using Breeze-viz. Experiment with different bin sizes.
import breeze.linalg._
import breeze.plot._
import com.github.tototoshi.csv._
import java.io.File

object prac14 {

 def main(args: Array[String]): Unit = {

   val reader = CSVReader.open(new File("used_cars_data.csv"))
   val data = reader.allWithHeaders()
   reader.close()

   // Extract Price values and remove empty rows
   val prices = DenseVector(
     data
       .filter(row => row("Price").trim.nonEmpty)
       .map(row => row("Price").trim.toDouble)
       .toArray
   )

   // Create histogram
   val fig = Figure("Histogram of Car Price")

   val binSizes = List(5, 10, 20)

   for ((bins, idx) <- binSizes.zipWithIndex) {

     val plt = fig.subplot(1, binSizes.length, idx)

     plt += hist(
       prices,
       bins
     )

     plt.title = s"Price Histogram ($bins bins)"
     plt.xlabel = "Price (Lakhs)"
     plt.ylabel = "Frequency"
   }

   fig.refresh()
 }
}
