# 12. Implement one-hot encoding for a categorical column in a dataset.
import com.github.tototoshi.csv._
import java.io.File

object prac12 {

 def main(args: Array[String]): Unit = {
   val reader = CSVReader.open(new File("used_cars_data.csv"))
   val data = reader.allWithHeaders()
   reader.close()

   // Get unique species
   val categories = data.map(_("Fuel_Type")).distinct.sorted

   val newData = data.map { row =>
     val species = row("Fuel_Type")
     val oneHot = categories.map(cat =>
       cat -> (if (cat == species) "1" else "0")
     ).toMap
     (row - "Fuel_Type") ++ oneHot
   }

   // Print the header
   val headers = newData.head.keys.toList
   println(headers.mkString(","))

   // Print each one-hot encoded row
   newData.foreach { row =>
     println(headers.map(row).mkString(","))
   }

   // Write output to new CSV file
   val writer = CSVWriter.open(new File("cars_encoded.csv"))
   writer.writeRow(headers)
   newData.foreach ( row => writer.writeRow(headers.map(row)))
   writer.close()

   println("One-hot encoded file written to cars_encoded.csv")
 }
}
