# 16. Combine two plots (e.g., scatter and line plot) in a single visualization using Breeze-viz. 
import breeze.linalg._
import breeze.plot._
import com.github.tototoshi.csv._
import java.io.File

object prac16 {

 def main(args: Array[String]): Unit = {

   val reader = CSVReader.open(new File("flower_dataset.csv"))
   val data = reader.allWithHeaders()
   reader.close()


   // Separate data by species
   val rose = data.filter(_("species") == "rose")
   val hibiscus = data.filter(_("species") == "hibiscus")
   val shoeblack = data.filter(_("species") == "shoeblack plant")

   // Extract height values
   def extractHeight(rows: List[Map[String, String]]) = {

     DenseVector(
       rows
         .filter(_("height_cm").trim.nonEmpty)
         .map(_("height_cm").trim.toDouble)
         .toArray
     )
   }

   val roseHeight = extractHeight(rose)
   val hibiscusHeight = extractHeight(hibiscus)
   val shoeblackHeight = extractHeight(shoeblack)

   // X values as index
   val xRose = DenseVector(
     (0 until roseHeight.length).map(_.toDouble).toArray
   )

   val xHibiscus = DenseVector(
     (0 until hibiscusHeight.length).map(_.toDouble).toArray
   )

   val xShoeblack = DenseVector(
     (0 until shoeblackHeight.length).map(_.toDouble).toArray
   )

   // Create plot
   val fig = Figure("Flower Height Line + Scatter Plot")

   val plt = fig.subplot(0)

   // Rose line
   plt += plot(
     xRose,
     roseHeight,
     name = "Rose Line",
     colorcode = "red"
   )

   // Rose scatter
   plt += plot(
     xRose,
     roseHeight,
     '.',
     name = "Rose Points",
     colorcode = "red"
   )

   // Hibiscus line
   plt += plot(
     xHibiscus,
     hibiscusHeight,
     name = "Hibiscus Line",
     colorcode = "blue"
   )

   // Hibiscus scatter
   plt += plot(
     xHibiscus,
     hibiscusHeight,
     '.',
     name = "Hibiscus Points",
     colorcode = "blue"
   )

   // Shoeblack plant line
   plt += plot(
     xShoeblack,
     shoeblackHeight,
     name = "Shoeblack Plant Line",
     colorcode = "green"
   )

   // Shoeblack plant scatter
   plt += plot(
     xShoeblack,
     shoeblackHeight,
     '.',
     name = "Shoeblack Plant Points",
     colorcode = "green"
   )

   plt.xlabel = "Flower Sample Index"
   plt.ylabel = "Height (cm)"
   plt.title = "Flower Height Line + Scatter Plot"

   plt.legend = true

   fig.refresh()
 }
}
