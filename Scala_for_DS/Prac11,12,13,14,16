# 15. Plot a line graph for a dataset showing a trend over time.
import breeze.linalg._
import breeze.plot._
import com.github.tototoshi.csv._
import java.io.File

object prac15 {

 def main(args: Array[String]): Unit = {

   val reader = CSVReader.open(new File("used_cars_data.csv"))
   val data = reader.allWithHeaders()
   reader.close()

   // Extract Year and Price, remove invalid values
   val parsedData = data.flatMap { row =>
     try {
       val year = row("Year").toDouble
       val price = row("Price").trim.toDouble
       Some((year, price))
     }
     catch {
       case _: Throwable => None
     }
   }.sortBy(_._1)

   // Prepare X (Year) and Y (Price)
   val x = DenseVector(
     parsedData.map(_._1).toArray
   )

   val y = DenseVector(
     parsedData.map(_._2).toArray
   )

   // Create line plot
   val fig = Figure("Car Price Trend")

   val plt = fig.subplot(0)

   plt += plot(
     x,
     y,
     name = "Car Price",
     colorcode = "blue"
   )

   plt.xlabel = "Manufacturing Year"
   plt.ylabel = "Price (Lakhs)"
   plt.title = "Used Car Price Trend by Year"

   fig.refresh()
 }
}
