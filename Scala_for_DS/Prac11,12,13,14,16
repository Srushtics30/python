# 13. Create a scatter plot of random data using Breeze-viz. Label the axes and customize the color of points.
import breeze.linalg._
import breeze.plot._
import com.github.tototoshi.csv._
import java.io.File

object prac13 {

 def main(args: Array[String]): Unit = {

   // Read CSV file
   val reader = CSVReader.open(new File("used_cars_data.csv"))
   val data = reader.allWithHeaders()
   reader.close()

   // Extract data based on Fuel Type
   val cng = data.filter(_("Fuel_Type") == "CNG")
   val diesel = data.filter(_("Fuel_Type") == "Diesel")
   val petrol = data.filter(_("Fuel_Type") == "Petrol")
   val lpg = data.filter(_("Fuel_Type") == "LPG")

   // Function to extract X and Y values
   def extractXY(rows: List[Map[String, String]]) = {

     val filtered = rows.filter { row =>
       row("Kilometers_Driven").trim.nonEmpty &&
         row("Price").trim.nonEmpty
     }

     val x = DenseVector(
       filtered.map(_("Kilometers_Driven").trim.toDouble).toArray
     )

     val y = DenseVector(
       filtered.map(_("Price").trim.toDouble).toArray
     )

     (x, y)
   }

   val (xCng, yCng) =
     extractXY(cng)

   val (xDiesel, yDiesel) =
     extractXY(diesel)

   val (xPetrol, yPetrol) =
     extractXY(petrol)

   val (xLpg, yLpg) =
     extractXY(lpg)

   // Create Scatter Plot
   val fig = Figure()

   val plt = fig.subplot(0)

   plt.xlim = (0, 1000000)
   plt.ylim = (0, 160)

   plt.title = "Kilometers Driven vs Car Price"

   plt.xlabel = "Kilometers Driven"

   plt.ylabel = "Price (Lakhs)"

   // CNG
   plt += plot(
     xCng,
     yCng,
     '.',
     name = "CNG",
     colorcode = "blue"
   )

   // Diesel
   plt += plot(
     xDiesel,
     yDiesel,
     '.',
     name = "Diesel",
     colorcode = "green"
   )

   // Petrol
   plt += plot(
     xPetrol,
     yPetrol,
     '.',
     name = "Petrol",
     colorcode = "red"
   )

   // LPG
   plt += plot(
     xLpg,
     yLpg,
     '.',
     name = "LPG",
     colorcode = "255,165,0"
   )

   fig.refresh()
 }
}
