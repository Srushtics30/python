# 10. Filter rows in a dataset where a specific column value exceeds a threshold. 
import com.github.tototoshi.csv._
import java.io.File

object FilterRowThreshold {
 def main(args: Array[String]): Unit = {

   val reader = CSVReader.open(new File("google_playstore_2026.csv"))
   val data = reader.allWithHeaders()
   reader.close()

   val threshold = 3.0

   // Rating > 3.0
   val greaterRows = data.filter { row =>
     row.get("Rating").exists(value => value.toDoubleOption.exists(_ > threshold))
   }

   // Rating < 3.0
   val smallerRows = data.filter { row =>
     row.get("Rating").exists(value => value.toDoubleOption.exists(_ < threshold))
   }

   // Rating == 3.0
   val equalRows = data.filter { row =>
     row.get("Rating").exists(value => value.toDoubleOption.exists(_ == threshold))
   }

   println(s"Rating > $threshold : ${greaterRows.length}")
   println(s"Rating < $threshold : ${smallerRows.length}")
   println(s"Rating == $threshold : ${equalRows.length}")
 }
} 
