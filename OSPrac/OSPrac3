# Threading and Single Thread Control Flow
import threading  #for creating and managing threads.
import time  #for adding delays and measuring execution time.

print("S116 - Srushti Vedak")
# Simulates a time-consuming function
def task(name):  #takes a name (like "Task 1")
    print(f"{name} started")  #shows when the task starts
    time.sleep(2)  # simulates work by pausing for 2 seconds
    print(f"{name} finished")  #shows when the task ends

#-------- Sequential Execution --------
print("\n--- Sequential Execution ---")  # Inform user about the execution mode: Sequential
start_time = time.time()  #saves current time to calculate duration later

task("Task 1")  #task 1 runs completely (2 seconds)
task("Task 2")  #task 2 runs (another 2 seconds), total time ≈ 4 seconds

end_time = time.time() #capture end time
print("Sequential Execution Time:", round(end_time - start_time, 2), "seconds")
#subtract start from end to get time taken & Round to 2 decimal places

# -------- Threaded Execution --------
print("\n--- Threaded Execution ---")  # Inform user about the execution mode:
threaded
start_time = time.time()  #records time before starting threads

#create threads
t1 = threading.Thread(target=task, args=("Task 1",))
#t1 and t2 are thread objects
#target=task: Function to run in the thread
#pass "Task 1" and "Task 2" as arguments

t2 = threading.Thread(target=task, args=("Task 2",))

# Launch both threads simultaneously
t1.start()
t2.start()
#starts both threads (they begin running in parallel)
#now task("Task 1") and task("Task 2") are running at the same time

#wait for threads to complete
t1.join()
t2.join()
# main thread waits until both t1 and t2 are done

end_time = time.time()  #time is now measured, since both tasks ran together, time ≈ 2 seconds (instead of 4)

print("Threaded Execution Time:", round(end_time - start_time, 2), "seconds")

