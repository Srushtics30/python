import tkinter as tk
from tkinter import messagebox

class Node:
    def __init__(self, data):
        self.data = data
        self.next = None

class LinkedList:
    def __init__(self):
        self.head = None

    def insert_beginning(self, data):
        node = Node(data)
        node.next = self.head
        self.head = node

    def insert_end(self, data):
        node = Node(data)

        if self.head is None:
            self.head = node
            return

        temp = self.head
        while temp.next:
            temp = temp.next

        temp.next = node

    def insert_position(self, data, pos):
        node = Node(data)

        if pos == 0:
            node.next = self.head
            self.head = node
            return

        temp = self.head

        for i in range(pos - 1):
            if temp is None:
                raise Exception("Invalid Position")
            temp = temp.next

        if temp is None:
            raise Exception("Invalid Position")

        node.next = temp.next
        temp.next = node

    def delete_value(self, value):
        temp = self.head

        if temp and temp.data == value:
            self.head = temp.next
            return True

        prev = None

        while temp:
            if temp.data == value:
                prev.next = temp.next
                return True

            prev = temp
            temp = temp.next

        return False

    def delete_index(self, pos):
        if self.head is None:
            raise Exception("List is empty")

        temp = self.head

        if pos == 0:
            self.head = temp.next
            return

        for i in range(pos - 1):
            if temp.next is None:
                raise Exception("Invalid Position")
            temp = temp.next

        temp.next = temp.next.next

    def display(self):
        result = ""
        temp = self.head

        while temp:
            result += str(temp.data) + "  ➜  "
            temp = temp.next

        return result + "NULL"


