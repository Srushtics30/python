import tkinter as tk
from tkinter import messagebox


stack = []


BG = "#0B1020"
FRAME = "#17203A"
PRIMARY = "#7C3AED"
SECONDARY = "#06B6D4"
SUCCESS = "#22C55E"
DANGER = "#EF4444"
TEXT = "#F8FAFC"
ENTRY_BG = "#E2E8F0"
OUTPUT_BG = "#CFFAFE"

def refresh():
    output.delete("1.0", tk.END)

    if len(stack) == 0:
        output.insert(tk.END, "STACK IS EMPTY")
        return

    output.insert(tk.END, "INDEX : VALUE\n")
    output.insert(tk.END, "----------------\n")

    for i, val in enumerate(stack):
        output.insert(tk.END, f"{i} : {val}\n")


def push():
    val = entry.get().strip()
    pos = pos_entry.get().strip()

    if val == "":
        messagebox.showwarning("Warning", "Enter value")
        return

    if pos == "":
        stack.append(val)
    else:
        try:
            index = int(pos)

            if index < 0 or index > len(stack):
                messagebox.showerror("Error", "Invalid Position")
                return

            stack.insert(index, val)

        except:
            messagebox.showerror("Error", "Position must be number")
            return

    entry.delete(0, tk.END)
    pos_entry.delete(0, tk.END)
    refresh()


def pop():
    if len(stack) == 0:
        messagebox.showinfo("Pop", "Stack is Empty")
    else:
        messagebox.showinfo("Pop", f"Popped: {stack.pop()}")
        refresh()


def peek():
    if len(stack) == 0:
        messagebox.showinfo("Peek", "Stack is Empty")
    else:
        messagebox.showinfo("Peek", f"Top: {stack[-1]}")


def size():
    messagebox.showinfo("Size", f"Size: {len(stack)}")


def is_empty():
    messagebox.showinfo("Is Empty", str(len(stack) == 0))


def traverse():
    if len(stack) == 0:
        messagebox.showinfo("Traverse", "Stack is Empty")
        return

    text = "TOP → BOTTOM\n\n"
    for i in reversed(range(len(stack))):
        text += f"{stack[i]}\n"

    messagebox.showinfo("Traverse", text)


def delimiter():
    exp = delim_entry.get().strip()

    if exp == "":
        messagebox.showwarning("Warning", "Enter expression")
        return

    temp = []
    pairs = {')': '(', ']': '[', '}': '{'}

    for ch in exp:
        if ch in "([{":
            temp.append(ch)

        elif ch in ")]}":
            if len(temp) == 0 or temp.pop() != pairs[ch]:
                messagebox.showinfo("Result", "Not Balanced")
                return

    if len(temp) == 0:
        messagebox.showinfo("Result", "Balanced")
    else:
        messagebox.showinfo("Result", "Not Balanced")


