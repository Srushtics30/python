import tkinter as tk
from tkinter import messagebox

class Node:
    def __init__(self, data):
        self.data = data
        self.next = None
        self.prev = None

class DoublyLinkedList:
    def __init__(self):
        self.head = None

    def insert_beginning(self, data):
        node = Node(data)

        if self.head is None:
            self.head = node
        else:
            node.next = self.head
            self.head.prev = node
            self.head = node

    def insert_end(self, data):
        node = Node(data)

        if self.head is None:
            self.head = node
            return

        temp = self.head

        while temp.next:
            temp = temp.next

        temp.next = node
        node.prev = temp

    def insert_position(self, data, pos):
        if pos == 0:
            self.insert_beginning(data)
            return

        temp = self.head

        for i in range(pos):
            if temp is None:
                raise Exception("Invalid Position")
            temp = temp.next

        if temp is None:
            raise Exception("Invalid Position")

        node = Node(data)

        node.next = temp
        node.prev = temp.prev

        if temp.prev:
            temp.prev.next = node

        temp.prev = node

    def delete_beginning(self):
        if self.head is None:
            return

        self.head = self.head.next

        if self.head:
            self.head.prev = None

    def delete_end(self):
        if self.head is None:
            return

        temp = self.head

        while temp.next:
            temp = temp.next

        if temp.prev:
            temp.prev.next = None
        else:
            self.head = None

    def delete_position(self, pos):
        temp = self.head

        for i in range(pos):
            if temp is None:
                raise Exception("Invalid Position")
            temp = temp.next

        if temp is None:
            raise Exception("Invalid Position")

        if temp.prev:
            temp.prev.next = temp.next
        else:
            self.head = temp.next

        if temp.next:
            temp.next.prev = temp.prev

    def display(self):
        result = ""
        temp = self.head

        while temp:
            result += str(temp.data) + " <-> "
            temp = temp.next

        return result + "NULL"

    def search(self, data):
        temp = self.head

        while temp:
            if temp.data == data:
                return True
            temp = temp.next

        return False

    def length(self):
        count = 0
        temp = self.head

        while temp:
            count += 1
            temp = temp.next

        return count


