# Write a program to implement doubly linked list with various operations. Command Line Code - 
import time
from colorama import init, Fore, Style

init(autoreset=True)

class Node:
    def __init__(self, data):
        self.data = data
        self.next = None
        self.prev = None

class DoublyLinkedList:
    def __init__(self):
        self.head = None

    def insert_at_beginning(self, data):
        new_node = Node(data)

        if self.head is None:
            self.head = new_node
        else:
            new_node.next = self.head
            self.head.prev = new_node
            self.head = new_node

    def insert_at_end(self, data):
        new_node = Node(data)

        if self.head is None:
            self.head = new_node
            return

        temp = self.head

        while temp.next:
            temp = temp.next

        temp.next = new_node
        new_node.prev = temp

    def insert_at_position(self, data, position):
        if position == 0:
            self.insert_at_beginning(data)
            return

        temp = self.head

        for i in range(position):
            if temp is None:
                raise IndexError("Position out of bounds.")
            temp = temp.next

        if temp is None:
            raise IndexError("Position out of bounds.")

        new_node = Node(data)

        new_node.next = temp
        new_node.prev = temp.prev

        if temp.prev:
            temp.prev.next = new_node

        temp.prev = new_node

    def delete_at_beginning(self):
        if self.head is None:
            return

        if self.head.next is None:
            self.head = None
        else:
            self.head = self.head.next
            self.head.prev = None

    def delete_at_end(self):
        if self.head is None:
            return

        if self.head.next is None:
            self.head = None
            return

        temp = self.head

        while temp.next:
            temp = temp.next

        temp.prev.next = None

    def delete_at_position(self, position):
        temp = self.head

        for i in range(position):
            if temp is None:
                raise IndexError("Position out of bounds.")
            temp = temp.next

        if temp is None:
            raise IndexError("Position out of bounds.")

        if temp.prev:
            temp.prev.next = temp.next

        if temp.next:
            temp.next.prev = temp.prev

        if position == 0:
            self.head = temp.next

    def display(self):
        if self.head is None:
            print(Fore.RED + "Doubly Linked List is empty.")
            return

        temp = self.head

        print(Fore.GREEN + "Doubly Linked List:")

        while temp:
            print(temp.data, end=" <-> ")
            temp = temp.next

        print("NULL")

    def search(self, data):
        temp = self.head

        while temp:
            if temp.data == data:
                return True
            temp = temp.next

        return False

    def length(self):
        count = 0
        temp = self.head

        while temp:
            count += 1
            temp = temp.next

        return count

def display_menu():
    print("\n" + "=" * 40)
    print(Style.BRIGHT + Fore.CYAN + "DOUBLY LINKED LIST OPERATIONS")
    print(Fore.YELLOW + "1. Insert at Beginning")
    print(Fore.YELLOW + "2. Insert at End")
    print(Fore.YELLOW + "3. Insert at Position")
    print(Fore.YELLOW + "4. Delete at Beginning")
    print(Fore.YELLOW + "5. Delete at End")
    print(Fore.YELLOW + "6. Delete at Position")
    print(Fore.YELLOW + "7. Display List")
    print(Fore.YELLOW + "8. Search Node")
    print(Fore.YELLOW + "9. Length of List")
    print(Fore.RED + "10. Exit")
    print("=" * 40)


def main():
    linked_list = DoublyLinkedList()

    while True:
        display_menu()

        try:
            choice = int(input("Enter your choice: "))

            if choice == 1:
                data = int(input("Enter data: "))
                linked_list.insert_at_beginning(data)
                print(Fore.GREEN + "Node inserted at beginning.")

            elif choice == 2:
                data = int(input("Enter data: "))
                linked_list.insert_at_end(data)
                print(Fore.GREEN + "Node inserted at end.")

            elif choice == 3:
                data = int(input("Enter data: "))
                position = int(input("Enter position: "))
                linked_list.insert_at_position(data, position)
                print(Fore.GREEN + "Node inserted.")

            elif choice == 4:
                linked_list.delete_at_beginning()
                print(Fore.RED + "Node deleted at beginning.")

            elif choice == 5:
                linked_list.delete_at_end()
                print(Fore.RED + "Node deleted at end.")

            elif choice == 6:
                position = int(input("Enter index: "))
                linked_list.delete_at_position(position)
                print(Fore.RED + "Node deleted.")

            elif choice == 7:
                linked_list.display()

            elif choice == 8:
                data = int(input("Enter data to search: "))

                if linked_list.search(data):
                    print(Fore.GREEN + "Node found.")
                else:
                    print(Fore.RED + "Node not found.")

            elif choice == 9:
                print(Fore.CYAN + "Length:", linked_list.length())

            elif choice == 10:
                print("Exiting...")
                break

            else:
                print(Fore.YELLOW + "Invalid choice.")

        except ValueError:
            print(Fore.YELLOW + "Enter valid integer.")

        except IndexError as e:
            print(Fore.RED + str(e))

        except Exception as e:
            print(Fore.RED + str(e))

        time.sleep(1)


if __name__ == "__main__":
    main()

