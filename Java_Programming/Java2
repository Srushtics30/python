}

// GUI Main class
public class AbstractEmpGUI extends JFrame {

    JTextField nameField;
    JButton fullTimeBtn, partTimeBtn;
    JTextArea resultArea;

    AbstractEmpGUI() {

        setTitle("Employee Salary Calculator");
        setSize(400, 300);
