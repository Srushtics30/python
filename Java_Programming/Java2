# GUI -
import javax.swing.*;
import java.awt.event.*;

// Interface
interface Shape {
    double calArea();
}

// Circle Class
class Circle implements Shape {
    double radius;

    Circle(double radius) {
        this.radius = radius;
    }

    public double calArea() {
        return 3.14 * radius * radius;
    }
}

// Rectangle Class
class Rectangle implements Shape {
    double length, width;

    Rectangle(double length, double width) {
        this.length = length;
        this.width = width;
    }

    public double calArea() {
        return length * width;
    }
}

// Main GUI Class
public class InterfaceShapeGUI {

    public static void main(String[] args) {

        JFrame frame = new JFrame("Shape Area Calculator");

        JLabel l1 = new JLabel("Radius:");
        JTextField radius = new JTextField();

        JLabel l2 = new JLabel("Length:");
        JTextField length = new JTextField();

        JLabel l3 = new JLabel("Width:");
        JTextField width = new JTextField();

        JButton circleBtn = new JButton("Circle Area");
        JButton rectBtn = new JButton("Rectangle Area");

        JLabel result = new JLabel("Result:");

        l1.setBounds(30,30,100,30);
        radius.setBounds(120,30,100,30);

        l2.setBounds(30,70,100,30);
        length.setBounds(120,70,100,30);

        l3.setBounds(30,110,100,30);
        width.setBounds(120,110,100,30);

        circleBtn.setBounds(30,160,120,30);
        rectBtn.setBounds(160,160,140,30);

        result.setBounds(30,220,250,30);


        circleBtn.addActionListener(new ActionListener() {
            public void actionPerformed(ActionEvent e) {

                double r = Double.parseDouble(radius.getText());

                Shape s = new Circle(r);

                result.setText("Circle Area = " + s.calArea());
            }
        });


        rectBtn.addActionListener(new ActionListener() {
            public void actionPerformed(ActionEvent e) {

                double l = Double.parseDouble(length.getText());
                double w = Double.parseDouble(width.getText());

                Shape s = new Rectangle(l,w);

                result.setText("Rectangle Area = " + s.calArea());
            }
        });


        frame.add(l1);
        frame.add(radius);

        frame.add(l2);
        frame.add(length);

        frame.add(l3);
        frame.add(width);


        frame.add(circleBtn);
        frame.add(rectBtn);

        frame.add(result);


        frame.setSize(350,320);
        frame.setLayout(null);
        frame.setVisible(true);
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
    }
}
