        nameField.setBounds(150, 30, 150, 30);
        add(nameField);

        fullTimeBtn = new JButton("Full Time Employee");
        fullTimeBtn.setBounds(30, 80, 160, 30);
        add(fullTimeBtn);

        partTimeBtn = new JButton("Part Time Employee");
        partTimeBtn.setBounds(200, 80, 150, 30);
        add(partTimeBtn);

        resultArea = new JTextArea();
        resultArea.setBounds(50, 140, 280, 80);
        add(resultArea);


        // Full-time button action
        fullTimeBtn.addActionListener(new ActionListener() {
            public void actionPerformed(ActionEvent e) {

                Employee emp = new FullTimeEmployee(nameField.getText());

                resultArea.setText(emp.display());
            }
        });


        // Part-time button action
        partTimeBtn.addActionListener(new ActionListener() {
            public void actionPerformed(ActionEvent e) {

                Employee emp = new PartTimeEmployee(nameField.getText());

                resultArea.setText(emp.display());
            }
        });

        setVisible(true);
    }


    public static void main(String[] args) {

        new AbstractEmpGUI();
    }
}

