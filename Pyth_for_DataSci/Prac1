1e. Store the names and marks of 5 students in a dictionary and then print each student’s name and marks, calculate and print the class average, and find the student with the highest marks. 
students = {
    "Amit": 85,
    "Priya": 92,
    "Rahul": 78,
    "Neha": 88,
    "Karan": 95
}

print("----- STUDENT MARKS -----")

for name, marks in students.items():
    print(name, ":", marks)

average = sum(students.values()) / len(students)
topper = max(students, key=students.get)

print("\n----- RESULT -----")
print("Class Average =", average)
print("Topper =", topper, "with", students[topper], "marks")

