#include <iostream>
using namespace std;

class Animal {
public:
    string name;
    int age;

    void eat() {
        cout << "Eating" << endl;
    }

    void sleep() {
        cout << "Sleeping" << endl;
    }
};


class Dog : public Animal {
public:
    string breed;

    void bark() {
        cout << "Barking" << endl;
    }
};


class Cat : public Animal {
public:
    string color;

    void meow() {
        cout << "Meowing" << endl;
    }
};

int main() {
    Dog d;
    Cat c;

    d.eat();
    d.bark();

    c.sleep();
    c.meow();

    return 0;
}
